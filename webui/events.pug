//DATA//
  events: DB.Find(null, { collection: 'event' })

-
  const enabled = events ? events.filter(e => e.enabled) : [];
  const disabled = events ? events.filter(e => !e.enabled) : [];

div
  .card.mb-4
    .card-header
      p.card-header-title
        span.icon
          i.mdi.mdi-plus-circle
        | Add Event
    .card-content
      form(method="post" action="/emit/chuniAddEvent")
        .field.is-grouped
          .control.is-expanded
            input.input(type="number" name="eventId" placeholder="Event ID" required)
          .control
            input.input(type="number" name="type" placeholder="Type (1=map, 2=story)" value="1")
          .control.is-expanded
            input.input(type="text" name="name" placeholder="Display name (optional)")
          .control
            input.input(type="text" name="startDate" placeholder="Start date (optional)")
          .control
            button.button.is-primary(type="submit") Add
        p.help.mb-0 Type 1 = map event, Type 2 = story event, Type 3 = limited. Events are sent to all cabinets on GetGameEvent.

  .columns
    .column
      .card
        .card-header
          p.card-header-title
            span.icon
              i.mdi.mdi-check-circle
            | Enabled (#{enabled.length})
        .card-content
          if enabled.length === 0
            p.has-text-grey No enabled events.
          else
            table.table.is-fullwidth.is-size-7
              thead
                tr
                  th ID
                  th Type
                  th Name
                  th Action
              tbody
                each e in enabled
                  tr
                    td #{e.eventId}
                    td #{e.type}
                    td #{e.name || '—'}
                    td
                      form(method="post" action="/emit/chuniToggleEvent" style="display:inline")
                        input(type="hidden" name="eventId" value=e.eventId)
                        input(type="hidden" name="enabled" value="false")
                        button.button.is-small.is-warning(type="submit") Disable
                      |  
                      form(method="post" action="/emit/chuniDeleteEvent" style="display:inline")
                        input(type="hidden" name="eventId" value=e.eventId)
                        button.button.is-small.is-danger(type="submit") ✕

    .column
      .card
        .card-header
          p.card-header-title
            span.icon
              i.mdi.mdi-minus-circle
            | Disabled (#{disabled.length})
        .card-content
          if disabled.length === 0
            p.has-text-grey No disabled events.
          else
            table.table.is-fullwidth.is-size-7
              thead
                tr
                  th ID
                  th Type
                  th Name
                  th Action
              tbody
                each e in disabled
                  tr
                    td #{e.eventId}
                    td #{e.type}
                    td #{e.name || '—'}
                    td
                      form(method="post" action="/emit/chuniToggleEvent" style="display:inline")
                        input(type="hidden" name="eventId" value=e.eventId)
                        input(type="hidden" name="enabled" value="true")
                        button.button.is-small.is-success(type="submit") Enable
                      |  
                      form(method="post" action="/emit/chuniDeleteEvent" style="display:inline")
                        input(type="hidden" name="eventId" value=e.eventId)
                        button.button.is-small.is-danger(type="submit") ✕
