//DATA//
  profile: DB.FindOne(refid, { collection: 'profile' })

-
  const p = profile || {};
  const name = p.userName || 'PLAYER';
  const level = p.level || 1;
  const rating = p.playerRating ? (p.playerRating / 100).toFixed(2) : '0.00';
  const highestRating = p.highestRating ? (p.highestRating / 100).toFixed(2) : '0.00';
  const plays = p.playCount || 0;
  const lastPlay = p.lastPlayDate || 'Never';
  const reincarnations = p.reincarnationNum || 0;

div
  .card
    .card-header
      p.card-header-title
        span.icon
          i.mdi.mdi-account
        | #{name}
        if reincarnations > 0
          span.tag.is-warning.ml-2 ✦#{reincarnations}
    .card-content
      .columns.is-multiline
        .column.is-narrow
          .has-text-centered
            p.heading Level
            p.title.is-3 #{level}
        .column.is-narrow
          .has-text-centered
            p.heading Rating
            p.title.is-3 #{rating}
        .column.is-narrow
          .has-text-centered
            p.heading Best Rating
            p.title.is-4.has-text-grey #{highestRating}
        .column.is-narrow
          .has-text-centered
            p.heading Play Count
            p.title.is-4 #{plays}
      p.has-text-grey.is-size-7 Last played: #{lastPlay}
      if p.trophyId
        p.has-text-grey.is-size-7 Trophy ID: #{p.trophyId}
      if p.nameplateId
        p.has-text-grey.is-size-7 Nameplate ID: #{p.nameplateId}
