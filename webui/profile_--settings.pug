//DATA//
  profile: DB.FindOne(refid, { collection: 'profile' })

-
  const p = profile || {};

div
  .card
    .card-header
      p.card-header-title
        span.icon
          i.mdi.mdi-account-edit
        | Profile Settings
    .card-content
      form(method="post" action="/emit/chuniUpdateProfile")
        input(type="hidden" name="refid" value=refid)

        .field
          label.label Username
          .control
            input.input(type="text" name="userName" value=p.userName placeholder="PLAYER" maxlength="8")
          p.help Max 8 characters

        .field
          label.label Trophy ID
          .control
            input.input(type="number" name="trophyId" value=p.trophyId placeholder="0")

        .field
          label.label Nameplate ID
          .control
            input.input(type="number" name="nameplateId" value=p.nameplateId placeholder="0")

        .field
          label.label Character ID
          .control
            input.input(type="number" name="characterId" value=p.characterId placeholder="10")

        .field
          .control
            button.button.is-primary(type="submit")
              span.icon
                i.mdi.mdi-content-save
              span Save Changes
