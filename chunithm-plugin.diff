diff --git a/webui/profile_main.pug b/webui/profile_main.pug
new file mode 100644
index 0000000..5700ebf
--- /dev/null
+++ b/webui/profile_main.pug
@@ -0,0 +1,172 @@
+//DATA//
+  profile: DB.FindOne({ __refid: refid })
+  songs: DB.FindOne({ __refid: refid }).then(p => p ? DB.Find({ userId: p.userId, collection: 'music' }) : [])
+  chars: DB.FindOne({ __refid: refid }).then(p => p ? DB.Find({ userId: p.userId, collection: 'character' }) : [])
+
+-
+  const p = profile || { userName: 'PLAYER', level: 1, playerRating: 0, playCount: 0 };
+
+  const GRADES = ['D','C','B','BB','BBB','A','AA','AAA','S','SA','SS','SSA','SSS','SSS+'];
+  const gradeLabel = (g) => GRADES[g] != null ? GRADES[g] : '?';
+
+  const CLEARS = {
+    0: 'Failed', 1: 'Clear', 2: 'Full Combo',
+    3: 'All Justice', 4: 'All Justice Critical'
+  };
+  const clearLabel  = (c) => CLEARS[c] || 'Unknown';
+
+  const CLEAR_TAG = {
+    0: 'is-danger', 1: 'is-info', 2: 'is-success',
+    3: 'is-warning', 4: 'is-primary'
+  };
+  const clearTag = (c) => CLEAR_TAG[c] || '';
+
+  const DIFF_LABEL = { 0:'BAS', 1:'ADV', 2:'EXP', 3:'MAS', 4:'ULT', 5:'WE' };
+  const DIFF_TAG   = { 0:'is-success', 1:'is-warning', 2:'is-danger', 3:'is-primary', 4:'is-dark', 5:'is-info' };
+  const diffLabel  = (d) => DIFF_LABEL[d] != null ? DIFF_LABEL[d] : d;
+  const diffTag    = (d) => DIFF_TAG[d] || '';
+
+  const fmt  = (n) => (n || 0).toLocaleString();
+  const rat  = (r) => r ? (r / 100).toFixed(2) : '0.00';
+
+  const safeSongs = songs || [];
+  const safeChars = chars || [];
+
+  const topSongs = safeSongs.slice().sort((a,b) => (b.scoreMax||0)-(a.scoreMax||0)).slice(0,50);
+  const topChars = safeChars.slice().sort((a,b) => (b.level||0)-(a.level||0));
+
+div
+  //- ── Profile Header ─────────────────────────────────────────────────
+  .card.mb-4
+    .card-header
+      p.card-header-title
+        span.icon
+          i.mdi.mdi-account
+        | #{p.userName || 'PLAYER'}
+        if p.reincarnationNum > 0
+          span.tag.is-warning.ml-2 ✦#{p.reincarnationNum}
+    .card-content
+      .columns.is-multiline
+        .column.is-narrow
+          .has-text-centered
+            p.heading Level
+            p.title.is-4 #{p.level || 1}
+        .column.is-narrow
+          .has-text-centered
+            p.heading Rating
+            p.title.is-4 #{rat(p.playerRating)}
+        .column.is-narrow
+          .has-text-centered
+            p.heading Best
+            p.title.is-5.has-text-grey #{rat(p.highestRating)}
+        .column.is-narrow
+          .has-text-centered
+            p.heading Plays
+            p.title.is-4 #{p.playCount || 0}
+        if p.trophyId
+          .column.is-narrow
+            .has-text-centered
+              p.heading Trophy
+              p.title.is-5 #{p.trophyId}
+        if p.nameplateId
+          .column.is-narrow
+            .has-text-centered
+              p.heading Nameplate
+              p.title.is-5 #{p.nameplateId}
+      if p.lastPlayDate
+        p.has-text-grey.is-size-7 Last played: #{p.lastPlayDate}
+
+  //- ── Score Summary ───────────────────────────────────────────────────
+  if safeSongs.length > 0
+    .card.mb-4
+      .card-header
+        p.card-header-title
+          span.icon
+            i.mdi.mdi-chart-bar
+          | Score Summary
+      .card-content
+        .columns.is-multiline
+          .column.is-narrow
+            .has-text-centered
+              p.heading Scored
+              p.title.is-4 #{safeSongs.length}
+          .column.is-narrow
+            .has-text-centered
+              p.heading Full Combo
+              p.title.is-4 #{safeSongs.filter(s=>s.isFullCombo).length}
+          .column.is-narrow
+            .has-text-centered
+              p.heading All Justice
+              p.title.is-4 #{safeSongs.filter(s=>s.isAllJustice).length}
+          .column.is-narrow
+            .has-text-centered
+              p.heading SSS+
+              p.title.is-4 #{safeSongs.filter(s=>s.grade>=13).length}
+
+  //- ── Best Scores Table ───────────────────────────────────────────────
+  .card.mb-4
+    .card-header
+      p.card-header-title
+        span.icon
+          i.mdi.mdi-music
+        | Best Scores
+        if safeSongs.length > 0
+          span.tag.is-light.ml-2 Top #{topSongs.length} / #{safeSongs.length}
+    .card-content
+      if safeSongs.length === 0
+        p.has-text-grey No scores saved yet.
+      else
+        .table-container
+          table.table.is-fullwidth.is-striped.is-hoverable.is-narrow
+            thead
+              tr
+                th Music ID
+                th Diff
+                th Score
+                th Grade
+                th Clear
+                th FC
+                th AJ
+            tbody
+              each s in topSongs
+                tr
+                  td #{s.musicId}
+                  td
+                    span.tag(class=diffTag(s.level)) #{diffLabel(s.level)}
+                  td
+                    strong #{fmt(s.scoreMax)}
+                  td
+                    span.tag.is-light #{gradeLabel(s.grade)}
+                  td
+                    span.tag(class=clearTag(s.clearStatus)) #{clearLabel(s.clearStatus)}
+                  td
+                    if s.isFullCombo
+                      span.icon.has-text-success ✔
+                  td
+                    if s.isAllJustice
+                      span.icon.has-text-warning ★
+
+  //- ── Characters ─────────────────────────────────────────────────────
+  if safeChars.length > 0
+    .card.mb-4
+      .card-header
+        p.card-header-title
+          span.icon
+            i.mdi.mdi-account-multiple
+          | Characters (#{safeChars.length})
+      .card-content
+        .columns.is-multiline
+          each c in topChars
+            .column.is-one-quarter-desktop.is-half-tablet
+              .box.p-3
+                .level.is-mobile
+                  .level-left
+                    p.has-text-weight-bold ID #{c.characterId}
+                  .level-right
+                    span.tag.is-info Lv #{c.level}
+                progress.progress.is-small.is-primary(
+                  value=c.exp max=100
+                  title=`EXP: ${c.exp}`)
+                p.is-size-7.has-text-grey Plays: #{c.playCount || 0}
+                if c.isEnlightenance
+                  span.tag.is-warning.is-light ★ Enlightened
